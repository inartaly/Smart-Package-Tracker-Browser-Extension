{
  "manifest_version": 3,
  "name": "Smart Package Tracker",
  "version": "1.0",
  "description": "Right-click any tracking number to detect the carrier and open tracking automatically.",
  "permissions": ["contextMenus", "tabs", "clipboardWrite", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png",
    "192": "icons/icon192.png",
    "512": "icons/icon512.png"
  }
}
